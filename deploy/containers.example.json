{
  "web": {
    "image": ":web",
    "ports": { "8000": "HTTP" },
    "environment": {
      "PORT": "8000",
      "DEBUG": "False",
      "DJANGO_SETTINGS_MODULE": "wms.settings",
      "ALLOWED_HOSTS": "example.com",
      "SECRET_KEY": "__SECRET_KEY__",
      "DB_NAME": "__DB_NAME__",
      "DB_USER": "__DB_USER__",
      "DB_PASSWORD": "__DB_PASSWORD__",
      "DB_PORT": "5432",
      "PGSSLMODE": "require",
      "USE_S3": "True",
      "AWS_ACCESS_KEY_ID": "__PROD_AWS_ACCESS_KEY_ID__",
      "AWS_SECRET_ACCESS_KEY": "__PROD_AWS_SECRET_ACCESS_KEY__",
      "AWS_S3_REGION": "us-west-2",
      "AWS_BEDROCK_REGION": "us-west-2",
      "DJANGO_SUPERUSER_EMAIL": "YOUR_EMAIL_HERE",
      "DJANGO_SUPERUSER_PASSWORD": "YOUR_SECURE_PASSWORD_HERE",
      "BETA_USER_EMAILS": "beta1@example.com,beta2@example.com",
      "BETA_USER_DEFAULT_PASSWORD": "ChangeMe123!",
      "REGISTRATION_ENABLED": "False"
    }
  }
}
